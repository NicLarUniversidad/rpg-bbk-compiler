<idea-plugin>
    <id>com.larena.boxbreaker.bbk</id>
    <name>BoxBreaker (BBK)</name>
    <vendor email="nic.lar.fts@gmail.com" url="https://github.com/NicLarUniversidad/rpg-bbk-compiler">NicoLarena</vendor>

    <description><![CDATA[
        Soporte de lenguaje BBK (BoxBreaker) en IntelliJ.
        En desarrollo activo.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="BBK File"
            implementationClass="com.larena.boxbreaker.plugin.bbk.BbkFileType"
            fieldName="INSTANCE"
            language="BBK"
            extensions="bbk"/>
        <lang.parserDefinition
            language="BBK"
            implementationClass="com.larena.boxbreaker.plugin.bbk.BbkParserDefinition"/>
        <lang.syntaxHighlighterFactory
            language="BBK"
            implementationClass="com.larena.boxbreaker.plugin.bbk.BbkSyntaxHighlighterFactory"/>

        <!-- Block A: basic autocomplete. -->
        <!-- (BbkWordsScanner exists in lexer/ and will be wired by BbkFindUsagesProvider in Block B.) -->

        <completion.contributor
            language="BBK"
            implementationClass="com.larena.boxbreaker.plugin.bbk.completion.BbkCompletionContributor"/>

        <!-- Brace pairs for auto-insertion + matching highlight + enter-between-braces. -->
        <lang.braceMatcher
            language="BBK"
            implementationClass="com.larena.boxbreaker.plugin.bbk.editor.BbkBraceMatcher"/>

        <!-- Smart typing polish: ; jumps past ), and closers skip-over their existing match. -->
        <typedHandler
            implementation="com.larena.boxbreaker.plugin.bbk.editor.BbkSmartTypingHandler"/>

        <!-- Block B: identifier resolution. -->
        <psi.referenceContributor
            language="BBK"
            implementation="com.larena.boxbreaker.plugin.bbk.reference.BbkReferenceContributor"/>

        <!-- Rename: reject reserved words and malformed identifiers. -->
        <renameInputValidator
            implementation="com.larena.boxbreaker.plugin.bbk.refactoring.BbkRenameInputValidator"/>

        <!-- Block C: stub element type holder + per-kind project-wide indexes. -->
        <stubElementTypeHolder
            class="com.larena.boxbreaker.plugin.bbk.stub.BbkStubElementTypes"
            externalIdPrefix="bbk."/>

        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkVariableIndex"/>
        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkConstantIndex"/>
        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkDataStructureIndex"/>
        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkDsSubfieldIndex"/>
        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkPrototypeIndex"/>
        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkProcedureIndex"/>
        <stubIndex implementation="com.larena.boxbreaker.plugin.bbk.index.BbkFileDeclarationIndex"/>

        <!-- Block A: live templates. -->
        <defaultLiveTemplates file="/liveTemplates/Bbk.xml"/>
        <liveTemplateContext
            contextId="BBK"
            implementation="com.larena.boxbreaker.plugin.bbk.templates.BbkLiveTemplateContext"/>
        <liveTemplateContext
            contextId="BBK_TOPLEVEL"
            baseContextId="BBK"
            implementation="com.larena.boxbreaker.plugin.bbk.templates.BbkTopLevelTemplateContext"/>
        <liveTemplateContext
            contextId="BBK_PROC_BODY"
            baseContextId="BBK"
            implementation="com.larena.boxbreaker.plugin.bbk.templates.BbkProcedureBodyTemplateContext"/>
    </extensions>
</idea-plugin>
